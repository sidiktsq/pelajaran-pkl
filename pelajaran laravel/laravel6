#Struktur View yang Disarankan

/resources
  /views
    /layouts      # Template master layout
    /partials     # Bagian kecil yang dapat digunakan kembali
    /components   # Component UI yang dapat digunakan kembali
    /pages        # Halaman spesifik
    /auth         # View autentikasi
    /errors       # Halaman error

# Passing Data ke View

// Cara 1: Array asosiatif
return view('greeting', ['name' => 'James', 'age' => 25]);

// Cara 2: Metode with()
return view('greeting')
        ->with('name', 'James')
        ->with('age', 25);

// Cara 3: Compact (menggunakan nama variabel)
$name = 'James';
$age = 25;
return view('greeting', compact('name', 'age'));