3.float

<?php
$pi = 3.14159;
$scientific = 1.5e3; // 1500
$negative = -2.7;

echo round($pi, 2); // 3.14
?>

4.boolean

<?php
$isActive = true;
$isComplete = false;

if ($isActive) {
    echo "Status: Aktif";
} else {
    echo "Status: Tidak Aktif";
}
?>

5.array

<?php
// Indexed Array
$fruits = array("apple", "banana", "orange");
$colors = ["red", "green", "blue"];

// Associative Array
$person = array(
    "name" => "John",
    "age" => 30,
    "city" => "Jakarta"
);

// Multidimensional Array
$students = array(
    array("Alice", 20, "Teknik Informatika"),
    array("Bob", 21, "Sistem Informasi"),
    array("Charlie", 19, "Teknik Komputer")
);
?>